# ─── Database ───
DATABASE_URL=postgresql://user:password@localhost:5432/omnichannel?connection_limit=10&pool_timeout=20
REDIS_URL=redis://localhost:6379

# ─── Auth ───
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars

# ─── Credential Encryption (AES-256-GCM) ───
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIALS_ENCRYPTION_KEY=your-64-char-hex-key

# ─── Telegram (MTProto) ───
TELEGRAM_API_ID=your-api-id
TELEGRAM_API_HASH=your-api-hash

# ─── Slack ───
SLACK_CLIENT_ID=your-client-id
SLACK_CLIENT_SECRET=your-client-secret
SLACK_SIGNING_SECRET=your-signing-secret

# ─── WhatsApp ───
WHATSAPP_SESSION_PATH=./sessions
WHATSAPP_VERIFY_TOKEN=your-whatsapp-verify-token

# ─── Gmail / Google OAuth ───
# These enable the "Connect with Google" OAuth button in the UI.
# Create at: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# Set authorized redirect URI to: {API_URL}/api/oauth/gmail/callback
GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret
# Optional overrides (defaults to GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET):
# GMAIL_CLIENT_ID=your-gmail-specific-client-id
# GMAIL_CLIENT_SECRET=your-gmail-specific-client-secret
# GMAIL_REDIRECT_URI=http://localhost:3001/api/oauth/gmail/callback

# ─── Cloudflare R2 ───
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=omnichannel-files
R2_PUBLIC_URL=https://files.yourdomain.com

# ─── App URLs ───
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
WS_URL=ws://localhost:3002

# ─── Ports ───
PORT=3001
WS_PORT=3002

# ─── Email (Resend) ───
# Sign up at https://resend.com and create an API key
# Without this key, invite/reset emails will be logged to console instead
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=Omnichannel <noreply@yourdomain.com>

# ─── Environment ───
NODE_ENV=development
